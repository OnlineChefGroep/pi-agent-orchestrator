{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentHandoff",
  "description": "Structured handoff format for chain-of-agents",
  "type": "object",
  "required": ["type", "status", "summary", "findings"],
  "properties": {
    "type": {
      "type": "string",
      "const": "handoff",
      "description": "Discriminator for handoff type"
    },
    "status": {
      "type": "string",
      "enum": ["success", "partial", "failed"],
      "description": "Completion status"
    },
    "summary": {
      "type": "string",
      "maxLength": 10000,
      "description": "Executive summary of findings"
    },
    "findings": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 100,
      "description": "List of findings"
    },
    "nextSteps": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Recommended follow-up actions"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence level (0.0-1.0)"
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Supporting evidence"
    },
    "files": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 200,
      "description": "Files referenced in findings"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "title", "content"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["code", "diff", "test", "doc", "config"]
          },
          "title": { "type": "string" },
          "content": {
            "type": "string",
            "maxLength": 50000
          },
          "language": { "type": "string" }
        }
      },
      "maxItems": 50,
      "description": "Structured artifacts"
    }
  },
  "additionalProperties": false,
  "securityLimits": {
    "maxJsonSize": "1MB",
    "maxNestingDepth": 20,
    "maxKeys": 1000,
    "maxSummaryLength": 10000,
    "maxStringLength": 50000
  }
}
