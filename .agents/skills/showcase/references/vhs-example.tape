# VHS Tape Example — Showcase Recording
# See: https://github.com/charmbracelet/vhs

Output docs/images/showcase_vhs.gif
Output docs/images/showcase_vhs.mp4

Require Node

Set FontSize 17
Set Width 110
Set Height 34
Set Padding 0
Set Margin 1
Set Theme "Dracula"
Set TypingSpeed 80ms

# Type "npm run build"
Type "npm run build"
Sleep 500ms
Enter
Sleep 3s

# Clear and show help
Ctrl+L
Sleep 500ms
Type "/agents help"
Sleep 500ms
Enter
Sleep 2s

# Dashboard
Ctrl+L
Sleep 500ms
Type "/agents"
Sleep 500ms
Enter
Sleep 3s

# Top view
Type "t"
Sleep 2s

# Back to dashboard
Type "t"
Sleep 2s

# Widget toggle
Type "w"
Sleep 2s

# Close
Type "q"
Sleep 500ms
