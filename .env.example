# Environment Variables for @onlinechefgroep/pi-agent-orchestrator
#
# Copy this file to .env and fill in the values.
# The extension reads these at runtime from process.env.
#
# Required (extension still works without these as no-ops):
PI_SUBAGENTS_LOG_LEVEL=warn           # Log level: debug | info | warn | error

# Optional: Feature flags (set to "true" or "false")
PI_FEATURE_SCHEDULING=true             # Enable cron scheduling
PI_FEATURE_TRACING=true                # Enable OpenTelemetry spans
PI_FEATURE_ERROR_TRACKING=false        # Enable Sentry error tracking (also needs SENTRY_DSN)
PI_FEATURE_ANALYTICS=false             # Enable product analytics (also needs POSTHOG_KEY)

# Optional: Error tracking (Sentry)
SENTRY_DSN=                            # https://key@sentry.io/project
SENTRY_ENVIRONMENT=development         # Environment name
SENTRY_RELEASE=                        # Release version (defaults to package.json version)
SENTRY_TRACES_SAMPLE_RATE=0.1          # Span sampling rate (0.0 - 1.0)

# Optional: Product analytics (PostHog)
POSTHOG_KEY=                           # PostHog project API key
ANALYTICS_KEY=                         # Fallback: same as POSTHOG_KEY
ANALYTICS_PROVIDER=posthog             # posthog | custom

# Optional: OpenTelemetry (configured by host application)
OTEL_EXPORTER_OTLP_ENDPOINT=           # OTLP exporter endpoint
OTEL_SERVICE_NAME=pi-agent-orchestrator # Service name for traces
