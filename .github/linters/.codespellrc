[codespell]
# Super-Linter runs `codespell --config .github/linters/.codespellrc`, so this file
# fully replaces the shipped default. The first five skips mirror that default
# (package-lock.json, go.mod, go.sum, *.log, .git). CHANGELOG.md is added because its
# historical v0.9.x release notes are written in Dutch, which codespell (English-only)
# reports as misspellings. Skipping the whole file is cleaner than maintaining an
# ignore-words-list of Dutch terms that might mask genuine typos elsewhere.
check-hidden =
skip = */package-lock.json,*/go.mod,*/go.sum,*.log,.git,*/CHANGELOG.md,CHANGELOG.md
