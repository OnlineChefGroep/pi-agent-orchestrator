{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noForEach": "warn",
				"noUselessLoneBlockStatements": "warn",
				"noUselessTernary": "warn",
				"useOptionalChain": "warn"
			},
			"style": {
				"recommended": false,
				"useTemplate": "warn"
			},
			"suspicious": {
				"noExplicitAny": "off",
				"noControlCharactersInRegex": "off",
				"noEmptyInterface": "off"
			},
			"correctness": {
				"noUnusedVariables": "warn"
			}
		}
	},
	"formatter": {
		"enabled": false
	},
	"files": {
		"includes": [
			"src/**/*.ts",
			"test/**/*.ts"
		]
	}
}
