{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/index.ts",
    "src/public-api.ts",
    "scripts/generate-showcase-media.mjs",
    "scripts/showcase-live-demo.mjs",
    "scripts/showcase-tmux-scenes.mjs",
    "test/compaction.benchmark.ts",
    "test/test-prompt-compression-programmatic.ts"
  ],
  "project": [
    "src/**/*.ts",
    "test/**/*.ts",
    "scripts/**/*.mjs"
  ],
  "ignore": [
    "src/ui/tui-shim.ts",
    "src/**/*.d.ts",
    "dist/**",
    "node_modules/**"
  ],
  "ignoreBinaries": [
    "tsx",
    "vitest",
    "biome",
    "droid",
    "graphify",
    "remotion",
    "typedoc",
    "node",
    "npx"
  ],
  "ignoreDependencies": [
    "@earendil-works/pi-ai",
    "@earendil-works/pi-coding-agent",
    "@earendil-works/pi-agent-core",
    "@vitest/coverage-v8",
    "typedoc"
  ]
}
