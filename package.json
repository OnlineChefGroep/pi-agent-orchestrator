{
  "name": "@onlinechefgroep/pi-agent-orchestrator",
  "version": "0.10.1",
  "description": "A pi extension for orchestrating autonomous coding agents, swarms, schedules, and handoffs.",
  "author": "OnlineChef",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OnlineChefGroep/pi-agent-orchestrator.git"
  },
  "homepage": "https://github.com/OnlineChefGroep/pi-agent-orchestrator#readme",
  "bugs": {
    "url": "https://github.com/OnlineChefGroep/pi-agent-orchestrator/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "subagent",
    "agent",
    "autonomous"
  ],
  "files": [
    "src/",
    "docs/",
    "examples/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.72.0",
    "@earendil-works/pi-coding-agent": ">=0.72.0",
    "@earendil-works/pi-tui": ">=0.72.0"
  },
  "peerDependenciesMeta": {
    "@onlinechef/context-mode": {
      "optional": true
    },
    "@onlinechefgroep/pi-subagents-tui": {
      "optional": true
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "croner": "^10.0.1",
    "nanoid": "^5.0.0"
  },
  "scripts": {
    "build": "NODE_OPTIONS='--max-old-space-size=4096' tsc",
    "test": "NODE_OPTIONS='--max-old-space-size=4096' vitest run --retry=2",
    "test:watch": "vitest",
    "typecheck": "NODE_OPTIONS='--max-old-space-size=4096' tsc --noEmit",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --fix src/ test/"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@earendil-works/pi-agent-core": "^0.77.0",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
