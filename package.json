{
  "name": "@onlinechef/pi-subagents",
  "version": "0.9.0",
  "description": "A pi extension extension that brings smart Claude Code-style autonomous sub-agents to pi.",
  "author": "OnlineChef",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OnlineChef/pi-subagents-fork"
  },
  "homepage": "https://github.com/OnlineChef/pi-subagents-fork#readme",
  "bugs": {
    "url": "https://github.com/OnlineChef/pi-subagents-fork/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "subagent",
    "agent",
    "autonomous"
  ],
  "peerDependencies": {
    "@mariozechner/pi-ai": ">=0.70.5",
    "@mariozechner/pi-coding-agent": ">=0.70.5",
    "@mariozechner/pi-tui": ">=0.70.5"
  },
  "peerDependenciesMeta": {
    "@onlinechef/context-mode": {
      "optional": true
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "croner": "^10.0.1",
    "nanoid": "^5.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --fix src/ test/"
  },
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
