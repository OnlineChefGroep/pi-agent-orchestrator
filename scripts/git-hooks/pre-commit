#!/usr/bin/env bash
#
# pre-commit — runs Biome lint (auto-fix) + typecheck on staged files.
# 100% local, no external dependencies.
#
# Skip: git commit --no-verify
#

set -e

# --- Collect staged .ts files ---
STAGED_FILES=$(git diff --cached --name-only -z --diff-filter=ACMR | tr '\0' '\n' | grep -E '\.(ts|js|mjs)$' || true)

if [ -z "$STAGED_FILES" ]; then
  echo "pre-commit: no .ts/.js files staged — skipping."
  exit 0
fi

COUNT=$(echo "$STAGED_FILES" | wc -l | tr -d ' ')
echo "pre-commit: checking ${COUNT} staged file(s)..."

# --- 1. Biome lint + auto-fix ---
echo "  → biome check --write --no-errors-on-unmatched"
if ! echo "$STAGED_FILES" | tr '\n' '\0' | xargs -0 npx biome check --write --no-errors-on-unmatched; then
  EXIT_CODE=$?
  echo ""
  echo "pre-commit: ❌ biome check exited with code ${EXIT_CODE}. Review and re-stage fixes."
  exit "${EXIT_CODE}"
fi

# Re-stage auto-fixed files (handles both new and modified files)
echo "$STAGED_FILES" | tr '\n' '\0' | xargs -0 git add -- 2>/dev/null || true

# --- 2. Typecheck (full project) ---
echo "  → tsc --noEmit"
if ! npx tsc --noEmit 2>&1; then
  echo ""
  echo "pre-commit: ❌ typecheck failed. Fix type errors and re-commit."
  echo "  (Tip: git commit --no-verify to bypass)"
  exit 1
fi

echo "pre-commit: ✅ all checks passed."
